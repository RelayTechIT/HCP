function Set-HCPAPIKey {
    param(
        $HCPAPI
    )
    
    if (test-path $HCPAPI) {
        $HCPAPIXML          =   import-clixml $HCPAPI
        $global:HCPAPICred         =   ConvertFrom-SecureString -SecureString $($HCPAPIXML) -AsPlainText
    } else {
        $global:HCPAPICred += @{"Authorization" =   "Bearer $($APIKey)"}
    }
}

function Get-HCPCustomer {
    param (
        [Parameter(Mandatory)]
        [ValidateSet("ANY","customer_id","SearchString", "location_ids")]
        [string]$MatchType,
        $MatchID,
        [switch]$include_attachments,
        [switch]$include_do_not_service,
        $PageSize,
        $ScheduledEndMax,
        $ScheduledStartMax,
        $ScheduledEndMin,
        $ScheduledStartMin,
        [ValidateSet("created_at","updated_at","id")]
        [string]$SortBy,
        [ValidateSet("asc","desc")]
        [string]$SortDirection,
        [ValidateSet("unscheduled","scheduled", "in_progress", "completed", "cancelled")]
        [switch]$WorkStatusUnscheduled,
        [switch]$WorkStatusScheduled,
        [switch]$WorkStatusInProgress,
        [switch]$WorkStatusCompleted,
        [switch]$WorkStatusCanceled
    )

    if (!$global:HCPAPICred) {
        Write-Host "You must set the HCP API Key with the Set-HCPAPIKey first!"
        Return
    } else {
        # HCP API Headers
        $headers = @{
            'Authorization' =   "Bearer $HCPAPICred"
            'Accept'        =   'application/json'
            'Method'        =   'Get'
        }
    }

    $BaseURI = "https://api.housecallpro.com/customers"
    $QueryParams = @()

    if ($MatchType -eq "customer_id") {
        $BaseURI += "/"+$MatchID
    } elseif ($MatchType -eq "SearchString") {
        $QueryParams += "q=$($MatchID)"
    } elseif ($MatchType -eq "location_ids") {
        Write-Host "Matching by location_ids isn't finished yet."
        Return
    } elseif ($MatchType -eq "ANY") {
        # for now do nothing
    } else {
        Write-Host "A MatchType is required to continue"
        Return
    }

    if ($include_attachments)     {$QueryParams += "expand[]=attachments"}
    if ($include_do_not_service)     {$QueryParams += "expand[]=do_not_service"}
    if ($Page)                  {$QueryParams += "page=$($Page)"}
    if ($PageSize)              {$QueryParams += "page_size=$($PageSize)"}
    if ($SortBy)                {$QueryParams += "sort_by=$($SortBy)"}
    if ($SortDirection)         {$QueryParams += "sort_direction=$($SortDirection)"}

    $URI = "$($BaseURI)?$($QueryParams -join '&')"

    # Write-Host "BaseURI is $($BaseURI)"
    Write-Host "QueryParams is $($QueryParams -join '&')"
    # Write-Host "Query is $($Query)"
        # Write-Host "URI is $($URI)"
    # Write-Host "Running query Invoke-RestMethod -Headers `$headers -Uri $($URI)"
    $QueryResults = Invoke-RestMethod -Headers $headers -Uri $URI

    if ($QueryResults.Customers) {
        return $QueryResults.Customers
    } else {
        return $QueryResults
    }
}

